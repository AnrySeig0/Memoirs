# Memoir Engine — environment template
# -----------------------------------------------------------------------------
# Copy to `.env` (gitignored) and edit. Every setting has a default in
# memoir/config.py so an empty .env still works against `docker compose up`.
# All app-level vars are prefixed `MEMOIR_`; Postgres/MinIO container vars use
# their image-native names (POSTGRES_*, MINIO_*) since docker-compose reads
# them directly.

# =============================================================================
# Database (memoir.store.db, alembic/env.py, tests/conftest.py)
# =============================================================================
# Runtime DSN — what FastAPI handlers and `uvicorn main:app` connect to.
MEMOIR_DATABASE_URL=postgresql+psycopg://memoir:memoir@localhost:5432/memoir

# Test DSN — what pytest connects to. Tests skip the DB suite cleanly
# if this URL is unreachable, so a laptop without docker still runs the
# pure-unit tests.
MEMOIR_TEST_DATABASE_URL=postgresql+psycopg://memoir:memoir@localhost:5432/memoir_test

# =============================================================================
# LLM extractor (memoir/extract/llm.py — M2 follow-up)
# =============================================================================
# Leave MEMOIR_LLM_BASE_URL unset to disable the LLM path entirely — the
# RuleExtractor baseline still works.
#
# For a local vLLM:
#   MEMOIR_LLM_BASE_URL=http://localhost:8000/v1
#   MEMOIR_LLM_API_KEY=EMPTY            # vLLM ignores the key
#   MEMOIR_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
#
# For OpenAI proper:
#   MEMOIR_LLM_BASE_URL=https://api.openai.com/v1
#   MEMOIR_LLM_API_KEY=sk-...
#   MEMOIR_LLM_MODEL=gpt-4o-mini
MEMOIR_LLM_BASE_URL=
MEMOIR_LLM_API_KEY=EMPTY
MEMOIR_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# 0.0 = greedy. §9 prefers under-extraction over creative guesses.
MEMOIR_LLM_TEMPERATURE=0.0

# Test-only overrides — control the live LLM smoke test in
# tests/test_extraction.py. If MEMOIR_LLM_TEST_BASE_URL is unset (and
# MEMOIR_LLM_BASE_URL is also unset) the live test is skipped. The
# *_MODEL and *_API_KEY overrides fall back to the main MEMOIR_LLM_* if
# omitted, so usually you only need to set MEMOIR_LLM_TEST_BASE_URL.
MEMOIR_LLM_TEST_BASE_URL=
MEMOIR_LLM_TEST_MODEL=
MEMOIR_LLM_TEST_API_KEY=

# =============================================================================
# Object storage (MinIO) — for future audio ingestion
# =============================================================================
MEMOIR_MINIO_ENDPOINT=localhost:9000
MEMOIR_MINIO_ACCESS_KEY=memoir
MEMOIR_MINIO_SECRET_KEY=memoir-secret
MEMOIR_MINIO_BUCKET=memoir

# =============================================================================
# Redis — for future Celery / Prefect orchestration
# =============================================================================
MEMOIR_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Container-side (docker-compose.yml reads these)
# =============================================================================
# These default to the same values as MEMOIR_DATABASE_URL above so a
# fresh `docker compose up -d` matches the app's expectations. Override
# in production to harden credentials.
POSTGRES_USER=memoir
POSTGRES_PASSWORD=memoir
POSTGRES_DB=memoir
POSTGRES_PORT=5432

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

REDIS_PORT=6379
